{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    "noEmit": true,
    "incremental": false,
    "composite": false,

    /* Allow ESLint to see JS/TS exactly as TS does */
    "allowJs": true,
    "checkJs": false
  },

  /* -------------------------------
   * ESLint MUST include the same files
   * TS uses — or you get "error" types
   * ------------------------------- */
  "include": [
    "next-env.d.ts",
    "global.d.ts",
    "src/**/*",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],

  "exclude": ["node_modules", ".next", "dist", "out", "public"]
}
