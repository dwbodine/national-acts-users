{
  "extends": "./tsconfig.json",

  "compilerOptions": {
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,

    "incremental": false,
    "composite": false
  },

  "include": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.mts", "**/*.cts"],

  "exclude": ["node_modules", ".next", "dist", "out", "public"]
}
