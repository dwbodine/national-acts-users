{
  "compilerOptions": {
    "composite": false,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "target": "ES2020",
    "resolveJsonModule": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },

  "include": ["src/**/*.ts", "src/**/*.tsx"],

  "exclude": ["node_modules", ".next", "dist", "out", "public"]
}
